# GitHub — required for PR URLs and remote repo tool calls
GITHUB_TOKEN=ghp_your_token_here

# LLM — vLLM direct (:8000) or pull-assist proxy (:9000)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct
LLM_MAX_TOKENS=1024

# Optional: native OpenAI tool calling (only if vLLM has --enable-auto-tool-choice)
# USE_NATIVE_TOOL_CALLING=false
