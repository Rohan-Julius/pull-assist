# Dockerfile for the FastAPI proxy layer
FROM python:3.11-slim

WORKDIR /app

# Install only proxy dependencies (lightweight)
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    requests \
    pydantic

# Copy only the server module
COPY server/ /app/server/

EXPOSE 9000

CMD ["uvicorn", "server.proxy:app", "--host", "0.0.0.0", "--port", "9000"]
